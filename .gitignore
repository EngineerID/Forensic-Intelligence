# --- Sovereign Audit Framework GitIgnore ---

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Environment & Credentials (CRITICAL)
.env
.venv
env/
venv/
ENV/
auth_key.json
*.pem

# Data & Forensics (Don't commit real raw datasets)
*.csv
*.xlsx
*.log
/data/raw/
/data/processed/

# Operating System
.DS_Store
Thumbs.db

# Database
*.db
*.sqlite

# IDEs
.vscode/
.idea/